{
	"name": "manakit",
	"version": "0.7.3",
	"description": "Manakit - Svelte library components",
	"author": "Nycolaide (laurent.grimaldi@minedelve.com)",
	"license": "MIT",
	"homepage": "https://minedelve.com",
	"repository": {
		"type": "git",
		"url": "git+https://github.com/minedelve/manakit.git"
	},
	"funding": {
		"type": "buymeacoffee",
		"url": "https://buymeacoffee.com/nycolaide"
	},
	"bugs": {
		"url": "https://github.com/minedelve/manakit/issues"
	},
	"keywords": [
		"svelte",
		"sveltekit",
		"components",
		"ui-library",
		"component-library",
		"component",
		"manakit",
		"minedelve",
		"design",
		"css",
		"ui",
		"svelte-component",
		"interface",
		"design-system",
		"theming",
		"framework",
		"typescript"
	],
	"scripts": {
		"dev": "vite dev",
		"build": "vite build && npm run package",
		"preview": "vite preview",
		"package": "svelte-kit sync && svelte-package && npm run clear && publint",
		"prepublishOnly": "npm run package",
		"check": "svelte-kit sync && svelte-check --tsconfig ./tsconfig.json",
		"check:watch": "svelte-kit sync && svelte-check --tsconfig ./tsconfig.json --watch",
		"clear": "rm -f dist/app.d.ts dist/app.html ",
		"lint": "prettier --check . && eslint .",
		"format": "prettier --write ."
	},
	"exports": {
		".": {
			"types": "./dist/index.d.ts",
			"svelte": "./dist/index.js",
			"default": "./dist/index.js"
		},
		"./vite": {
			"types": "./dist/preprocess.d.ts",
			"default": "./dist/preprocess.js"
		},
		"./style/css": "./dist/style.css",
		"./style/variables": "./dist/_variables.scss"
	},
	"files": [
		"dist",
		"README.md",
		"LICENSE"
	],
	"peerDependencies": {
		"svelte": "^4.0.0"
	},
	"devDependencies": {
		"@sveltejs/adapter-auto": "^3.0.0",
		"@sveltejs/kit": "^2.0.0",
		"@sveltejs/package": "^2.0.0",
		"@sveltejs/vite-plugin-svelte": "^3.0.0",
		"@types/eslint": "^8.56.0",
		"@types/node": "^20.14.7",
		"@typescript-eslint/eslint-plugin": "^7.0.0",
		"@typescript-eslint/parser": "^7.0.0",
		"chalk": "^5.3.0",
		"eslint": "^8.56.0",
		"eslint-config-prettier": "^9.1.0",
		"eslint-plugin-svelte": "^2.35.1",
		"prettier": "^3.1.1",
		"prettier-plugin-svelte": "^3.1.2",
		"publint": "^0.1.9",
		"svelte": "^4.2.7",
		"svelte-check": "^3.6.0",
		"tslib": "^2.4.1",
		"typescript": "^5.0.0",
		"vite": "^5.0.11"
	},
	"dependencies": {},
	"svelte": "./dist/index.js",
	"types": "./dist/index.d.ts",
	"type": "module",
	"packageManager": "yarn@1.22.22"
}
